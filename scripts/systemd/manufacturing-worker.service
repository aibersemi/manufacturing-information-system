[Unit]
Description=Manufacturing IS - Background Worker (Dramatiq)
After=network.target postgresql.service redis-server.service

[Service]
Type=simple
User=mrdev
Group=mrmads-group
WorkingDirectory=/opt/services/manufacturing-information-system
EnvironmentFile=/opt/services/manufacturing-information-system/.env

ExecStart=/opt/services/manufacturing-information-system/.venv/bin/dramatiq backend.core.tasks

Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
