{
	"$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"a11y": {
				"useButtonType": "warn",
				"useAltText": "error",
				"noAriaHiddenOnFocusable": "error"
			}
		}
	},
	"files": {
		"includes": [
			"**",
			"!**/.venv",
			"!**/node_modules",
			"!**/dist",
			"!**/frontend/src/api/generated",
			"!**/frontend/schema.json",
			"!**/*.gen.*",
			"!**/backend",
			"!**/plan",
			"!**/docs",
			"!**/scripts",
			"!**/frontend/src/styles/globals.css"
		]
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always"
		}
	}
}
