{
	"name": "manufacturing-information-system",
	"version": "1.0.0",
	"private": true,
	"sponsor": {
		"url": "https://saweria.co/aibersemi"
	},
	"workspaces": [
		"frontend"
	],
	"type": "module",
	"scripts": {
		"dependencies:check": "node scripts/check_frontend_dependencies.mjs",
		"prebuild": "npm run dependencies:check",
		"prelint": "npm run dependencies:check",
		"pretest": "npm run dependencies:check",
		"pretypecheck": "npm run dependencies:check",
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"lint": "npm run lint:jsx-dom-spread && npm run lint:property-access-security && npm run lint:ui-safe-rendering && npm run lint:i18n-literals && npm run lint:zod-mutations && npm run lint:paraglide-security && biome check .",
		"lint:fix": "npm run lint:jsx-dom-spread && npm run lint:property-access-security && npm run lint:ui-safe-rendering && npm run lint:i18n-literals && npm run lint:zod-mutations && npm run paraglide:security-patch && biome check --write .",
		"lint:accordion-security": "npm run lint:ui-safe-rendering",
		"lint:chart-security": "npm run lint:property-access-security",
		"lint:dashboard-security": "npm run lint:property-access-security",
		"lint:property-access-security": "node scripts/check_chart_safe_property_access.mjs",
		"lint:reports-security": "npm run lint:property-access-security",
		"lint:ui-safe-rendering": "node scripts/check_ui_safe_rendering.mjs",
		"lint:i18n-literals": "node scripts/check_i18n_literals.mjs",
		"lint:jsx-dom-spread": "node scripts/check_jsx_dom_spread.mjs",
		"lint:paraglide-security": "npm run paraglide:security-check",
		"lint:zod-mutations": "node scripts/check_zod_mutation_guards.mjs",
		"paraglide:security-patch": "node scripts/patch_paraglide_security.mjs",
		"paraglide:security-check": "node scripts/patch_paraglide_security.mjs --check",
		"paraglide:security-test": "node scripts/test_paraglide_runtime_security.mjs",
		"test": "npm run paraglide:security-check && npm run paraglide:security-test && tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
		"test:frontend": "npm run paraglide:security-check && npm run paraglide:security-test && vitest run && npm run paraglide:security-patch && npm run paraglide:security-check && npm run paraglide:security-test",
		"typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
		"generate:api": ".venv/bin/python scripts/export_schema.py frontend/schema.json && orval && .venv/bin/python scripts/normalize_generated.py frontend/src/api/generated",
		"contract:check": "bash scripts/check_contract.sh"
	},
	"dependencies": {
		"@radix-ui/react-accordion": "1.2.15",
		"@radix-ui/react-alert-dialog": "1.1.18",
		"@radix-ui/react-avatar": "1.2.1",
		"@radix-ui/react-checkbox": "1.3.6",
		"@radix-ui/react-collapsible": "1.1.15",
		"@radix-ui/react-dialog": "1.1.18",
		"@radix-ui/react-dropdown-menu": "2.1.19",
		"@radix-ui/react-label": "2.1.11",
		"@radix-ui/react-popover": "1.1.18",
		"@radix-ui/react-progress": "1.1.11",
		"@radix-ui/react-radio-group": "1.4.2",
		"@radix-ui/react-scroll-area": "1.2.13",
		"@radix-ui/react-select": "2.3.2",
		"@radix-ui/react-separator": "1.1.11",
		"@radix-ui/react-slot": "1.3.0",
		"@radix-ui/react-switch": "1.3.2",
		"@radix-ui/react-tabs": "1.1.16",
		"@radix-ui/react-toggle": "1.1.13",
		"@radix-ui/react-toggle-group": "1.1.14",
		"@radix-ui/react-tooltip": "1.2.11",
		"@tanstack/react-form": "1.33.0",
		"@tanstack/react-query": "5.101.0",
		"@tanstack/react-ranger": "0.0.5",
		"@tanstack/react-router": "1.170.16",
		"@tanstack/react-store": "0.11.0",
		"@tanstack/react-table": "8.21.3",
		"@tanstack/react-virtual": "3.14.3",
		"class-variance-authority": "0.7.1",
		"clsx": "2.1.1",
		"cmdk": "1.1.1",
		"date-fns": "4.4.0",
		"dotenv": "17.4.2",
		"lucide-react": "1.22.0",
		"next-themes": "0.4.6",
		"react": "19.2.7",
		"react-day-picker": "10.0.1",
		"react-dom": "19.2.7",
		"recharts": "2.15.4",
		"sonner": "2.0.7",
		"tailwind-merge": "3.6.0",
		"vaul": "1.1.2",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.0",
		"@inlang/paraglide-js": "2.20.0",
		"@inlang/plugin-m-function-matcher": "2.2.9",
		"@inlang/plugin-message-format": "4.4.0",
		"@playwright/test": "1.61.1",
		"@tailwindcss/vite": "4.3.1",
		"@types/node": "24.13.2",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.2",
		"orval": "8.18.0",
		"playwright": "1.61.1",
		"shadcn": "4.12.0",
		"tailwindcss": "4.3.1",
		"typescript": "6.0.3",
		"vite": "8.0.16",
		"vite-plugin-biome": "1.2.0",
		"vitest": "4.1.9"
	},
	"overrides": {
		"@babel/plugin-transform-runtime": "7.29.7"
	}
}
